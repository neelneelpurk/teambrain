# Promotion workflow: a note routes itself to a team via its teambrains property.
[!exec:git] skip 'git not installed'
env XDG_CONFIG_HOME=$WORK/cfg

# Personal vault + a team vault that is a real git repo, bound as "eng".
exec teambrain init $WORK/personal
exec teambrain team init $WORK/team
exec git -C $WORK/team init
exec git -C $WORK/team config user.email t@example.com
exec git -C $WORK/team config user.name T
exec git -C $WORK/team config commit.gpgsign false
exec git -C $WORK/team add -A
exec git -C $WORK/team commit -m init
exec teambrain team bind $WORK/team --name eng --vault $WORK/personal

# A note tagged for "eng" that links to a personal-only note.
cp linker.md $WORK/personal/projects/linker.md

exec teambrain create-sync projects/linker.md --vault $WORK/personal
exists $WORK/personal/_sync/eng/adrs/0001.md

# view-sync groups by team and flags the dangling link.
exec teambrain --json view-sync --vault $WORK/personal
stdout '"team": "eng"'
stdout 'private-thoughts'

# The note has a link that would dangle in the team vault, so commit-sync is
# refused without --force — the link gate is real, not just a report.
! exec teambrain commit-sync --yes --vault $WORK/personal
stderr 'dangle'
exists $WORK/personal/_sync/eng/adrs/0001.md

# With --force (and --yes to skip the shared-repo confirmation) it promotes and
# commits only that file.
exec teambrain commit-sync --force --yes --vault $WORK/personal
exists $WORK/team/adrs/0001.md
! exists $WORK/personal/_sync/eng/adrs/0001.md
exec git -C $WORK/team log --name-only -1
stdout 'adrs/0001.md'

-- linker.md --
---
title: Linker
teambrains: [eng]
teambrain_dest: adrs/0001.md
---
see [[private-thoughts]] and [[conventions/style]]
